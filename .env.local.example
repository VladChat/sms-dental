# Local secrets only.
# Keep real values on your computer or in Vercel environment variables.
# Do not commit .env.local.
# Do not place public domains, feature flags, product settings, onboarding rules, service resource SIDs, sender email config, or other non-secret application settings here.

# Supabase secrets
SUPABASE_DB_URL=
SUPABASE_DB_DIRECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Stripe secrets
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel API token
VERCEL_TOKEN=

# Resend API key
RESEND_API_KEY=

# Platform admin console — comma-separated allowlist of platform-admin emails.
# Non-secret, but kept here so the operator sets it alongside other env values.
# Real value belongs in local/Vercel env only (e.g. PLATFORM_ADMIN_EMAILS=you@example.com).
PLATFORM_ADMIN_EMAILS=