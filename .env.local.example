# Local secrets only.
# Keep real values on your computer or in Vercel environment variables.
# Do not commit .env.local.
# Do not place public domains, feature flags, product settings, onboarding rules, service resource SIDs, sender email config, or other non-secret application settings here.

# Supabase secrets
SUPABASE_DB_URL=
SUPABASE_DB_DIRECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Stripe secrets (sandbox/test mode for the payment-method setup milestone)
# STRIPE_SECRET_KEY must be a Stripe TEST/sandbox secret key (starts with sk_test_).
#   The payment-method setup flow refuses to run unless this is a test key.
# STRIPE_WEBHOOK_SECRET must be the signing secret (whsec_…) from the Stripe
#   TEST/sandbox webhook endpoint that points to /api/webhooks/stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe TEST-mode recurring Price IDs for subscription billing (non-secret, but
# env-managed because test and live IDs differ). Base plan = $99/mo; additional
# business number = $20/mo. Server-only; never sent to the client.
STRIPE_BASE_PLAN_PRICE_ID=
STRIPE_ADDITIONAL_NUMBER_PRICE_ID=

# Vercel API token
VERCEL_TOKEN=

# Resend API key
RESEND_API_KEY=

# Platform admin console — comma-separated allowlist of platform-admin emails.
# Non-secret, but kept here so the operator sets it alongside other env values.
# Real value belongs in local/Vercel env only (e.g. PLATFORM_ADMIN_EMAILS=you@example.com).
PLATFORM_ADMIN_EMAILS=