# Safe example template for local development.
# This file is commit-safe and must contain placeholders only.
# Copy values into your untracked `.env.local` file on your machine.

# Supabase secret
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio secret
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_PHONE_NUMBER_SID=
TWILIO_MESSAGING_SERVICE_SID=

# Stripe secrets
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_ID=

# Internal local secrets
JOB_RUNNER_SECRET=
INTERNAL_ADMIN_SECRET=

# Public base URL the backend is reachable at, used to reconstruct the URL
# Twilio signed when validating x-twilio-signature. Leave blank in local dev
# and the request URL will be used directly. Set in production (e.g.
# https://app.missedcallsdental.com) so signature verification matches the
# URL Twilio actually called.
PUBLIC_WEBHOOK_BASE_URL=

# SMS recovery mode. Controls whether outbound SMS is sent.
#   disabled   — no SMS sent (default, safe)
#   owner_test — SMS sent only to numbers in SMS_TEST_ALLOWED_TO
#   live       — not yet supported
SMS_RECOVERY_MODE=

# Comma-separated E.164 numbers allowed to receive SMS in owner_test mode.
# Example: +12225551234,+13335556789
# Only used when SMS_RECOVERY_MODE=owner_test.
SMS_TEST_ALLOWED_TO=

# Onboarding workflow — required in production.
# APP_BASE_URL must point at the app/backend domain (NOT the marketing apex).
# Setup links sent by email are composed from APP_BASE_URL only.
# PUBLIC_SITE_URL is the marketing apex domain. It is used as the allowed
# Origin for cross-origin POSTs from the docs site.
APP_BASE_URL=
PUBLIC_SITE_URL=

# Resend setup-link email delivery. Required when the owner-test fallback
# below is NOT enabled. Production must use real email delivery.
RESEND_API_KEY=
SETUP_EMAIL_FROM=

# Twilio number purchase safety gate. Number search is allowed regardless,
# but purchase only proceeds when this is exactly "true".
TWILIO_NUMBER_PURCHASE_ENABLED=false

# Owner-test setup link fallback. When set to exactly "true", POST
# /api/setup-requests returns the setup link in the JSON response instead
# of sending email. Use only for local owner testing. Never enable in
# production.
OWNER_TEST_SETUP_LINK_FALLBACK=false
