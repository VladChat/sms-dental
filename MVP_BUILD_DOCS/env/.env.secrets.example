# Secrets only.
# Copy real development/test values into .env.local for local development.
# Do not commit real values.
# In staging/production, store real values in Vercel Environment Variables or a secure vault.

# Supabase private server-side secret
SUPABASE_SERVICE_ROLE_KEY=

# Twilio private credentials
# Prefer API Key auth for app runtime when possible.
# TWILIO_AUTH_TOKEN may still be needed for signature validation or legacy SDK setup.
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SECRET=

# Stripe private credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Internal shared secrets
JOB_RUNNER_SECRET=
INTERNAL_ADMIN_SECRET=

# Optional: only if CI needs Sentry release/source-map upload
# SENTRY_AUTH_TOKEN=
