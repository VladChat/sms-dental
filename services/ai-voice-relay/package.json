{
  "name": "ai-voice-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Twilio ConversationRelay WebSocket relay for Missed Calls Dental AI Answering (test_only). Deploys independently from the Next app.",
  "main": "dist/services/ai-voice-relay/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/services/ai-voice-relay/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-tests/services/ai-voice-relay/tests/setup-validation.test.js .tmp-tests/services/ai-voice-relay/tests/prompt-handling.test.js .tmp-tests/services/ai-voice-relay/tests/openai-brain.test.js .tmp-tests/services/ai-voice-relay/tests/session-lifecycle.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "postgres": "^3.4.5",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
